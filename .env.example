# Conexão com o PostgreSQL.
# Recomendado: Neon (nuvem) — mesma URL em dev e produção, nada pra instalar.
DATABASE_URL=postgresql://usuario:senha@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Alternativa local (só se NÃO usar DATABASE_URL): descomente e preencha.
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=sua_senha
# PGDATABASE=cupido

PORT=3100

# Credencial do login (gate do PI). Valores reais só no .env local e no host — nunca aqui.
AUTH_EMAIL=voce@exemplo.com
AUTH_SENHA=troque_por_uma_senha

# Em produção o host define NODE_ENV=production (ativa cookie secure). Local: deixe vazio.
# NODE_ENV=production
